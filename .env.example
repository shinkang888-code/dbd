# Neon PostgreSQL (pooled connection string)
DATABASE_URL=

# Neon Auth (Managed BetterAuth)
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Admin allowlist (comma-separated). Empty = any signed-in user in dev.
ADMIN_EMAILS=

# Public app URL (결제 콜백/리다이렉트)
NEXT_PUBLIC_APP_URL=https://lexi0.vercel.app

# USD → KRW (토스·다날 청구). 기본 1350
USD_KRW_RATE=1350

# --- LawyGo 이식: Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- 토스페이먼츠 ---
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# --- LawyGo/lawygofind 이식: 다날 ---
NEXT_PUBLIC_DANAL_CLIENT_KEY=
DANAL_CLIENT_KEY=
DANAL_SECRET_KEY=
DANAL_MERCHANT_ID=
DANAL_SANDBOX=true

# --- Cafe24 Open API (헤드리스 백엔드) ---
# 개발자센터 앱 + 쇼핑몰 설치 후 발급
CAFE24_MALL_ID=
CAFE24_SHOP_NO=1
CAFE24_API_VERSION=2026-03-01
CAFE24_MODE=front
CAFE24_FRONT_CLIENT_ID=
CAFE24_FRONT_API_KEY=
# Admin 주문/상품 쓰기·Sync용 OAuth access token
CAFE24_ACCESS_TOKEN=

# Vercel 배포 별칭 베이스 (기본 lexi → lexi0,1,2… 폴백)
LEXI_ALIAS_BASE=lexi

# --- 역직구 HQ (스펙 §9.4) ---
HQ_API_TOKEN=
CRON_SECRET=
CJ_API_EMAIL=
CJ_API_KEY=
COUPANG_VENDOR_ID=
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
SUPERBUY_APP_KEY=
SUPERBUY_APP_SECRET=
