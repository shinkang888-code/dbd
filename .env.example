# Neon PostgreSQL (pooled connection string)
DATABASE_URL=

# Neon Auth (Managed BetterAuth)
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Admin allowlist (comma-separated). Empty = any signed-in user in dev.
ADMIN_EMAILS=

# 데모 로그인 (기본 ON). 끄려면 0
DEMO_LOGIN=1

# Public app URL (결제 콜백/리다이렉트) — 대시보드 배포 URL
NEXT_PUBLIC_APP_URL=https://dbd-beta.vercel.app

# 고객 몰(lexistyle) — Studio/Admin에서 "몰 열기" 링크
NEXT_PUBLIC_MALL_URL=http://localhost:3000

# USD → KRW (토스·다날 청구). 기본 1350
USD_KRW_RATE=1350

# --- LawyGo 이식: Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- 토스페이먼츠 ---
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# --- LawyGo/lawygofind 이식: 다날 ---
NEXT_PUBLIC_DANAL_CLIENT_KEY=
DANAL_CLIENT_KEY=
DANAL_SECRET_KEY=
DANAL_MERCHANT_ID=
DANAL_SANDBOX=true

# --- Cafe24 Open API (헤드리스 백엔드) ---
# 개발자센터 앱 + 쇼핑몰 설치 후 발급
CAFE24_MALL_ID=
CAFE24_SHOP_NO=1
CAFE24_API_VERSION=2026-03-01
CAFE24_MODE=front
CAFE24_FRONT_CLIENT_ID=
CAFE24_FRONT_API_KEY=
CAFE24_CLIENT_SECRET=
# 개발자센터 앱에 등록한 권한과 정확히 일치해야 함(불일치 시 invalid_scope). 기본: 카탈로그 최소 권한
CAFE24_SCOPES=mall.read_product
# Admin 주문/상품 쓰기·Sync용 OAuth access token
CAFE24_ACCESS_TOKEN=
NEXT_PUBLIC_CAFE24_ADMIN_URL=https://eclogin.cafe24.com/Shop/

# Vercel 배포 별칭 베이스 (기본 lexi → lexi0,1,2… 폴백)
LEXI_ALIAS_BASE=lexi

# Remotion 워커 (미설정 시 storyboard preview — D-006)
REMOTION_WORKER_URL=

# Legacy LEXI 상품/주문 쓰기 (기본 off — Cafe24 SSOT)
NEXT_PUBLIC_LEGACY_COMMERCE_WRITE=false

# --- Hybrid Distributed Ledger (LawyGo HDL 이식) ---
# false 로 끄기. 기본 활성
LEDGER_ENABLED=true
LEDGER_TENANT_ID=dbd
LEDGER_BLOCK_TX_THRESHOLD=50
LEDGER_BLOCK_INTERVAL_MIN=15
# dbd_timestamp_v1 | opentimestamps | polygon (향후 DLT)
LEDGER_ANCHOR_PROVIDER=dbd_timestamp_v1
# OPENTIMESTAMP_CALENDAR=https://a.pool.opentimestamps.org

# --- 역직구 HQ (스펙 §9.4) ---
HQ_API_TOKEN=
CRON_SECRET=
CJ_API_EMAIL=
CJ_API_KEY=
COUPANG_VENDOR_ID=
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
SUPERBUY_APP_KEY=
SUPERBUY_APP_SECRET=

# Alibaba / 1688 Open Platform (Cloud LTAI 키와 별개)
ALIBABA_OPEN_APP_KEY=
ALIBABA_OPEN_APP_SECRET=
ALIBABA_OPEN_BASE=

# Temu (공식 소싱 API 없을 때 목업 폴백)
TEMU_PARTNER_TOKEN=
TEMU_APP_KEY=
TEMU_APP_SECRET=
